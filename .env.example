# Copy to .env for local development. Every NEXT_PUBLIC_* var is bundled
# into the client JS, so never put secrets in one.

# Displayed brand name (nav, footer, dashboards, page title)
NEXT_PUBLIC_APP_NAME=ELEVATE

# Base path the frontend calls for API routes. Keep as /api unless the
# backend is split onto a different origin.
NEXT_PUBLIC_API_BASE_URL=/api

# Locale served on first load before the user toggles the language switch.
# One of: en, ar
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Server-only: canonical origin used for absolute metadata/OG URLs.
# Never exposed to the browser bundle.
SITE_URL=http://localhost:3000
